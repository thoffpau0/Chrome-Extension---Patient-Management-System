{
  "name": "Vet Radar Notification",
  "version": "1.0",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.bundle.js"
  },
  "permissions": [
    "contextMenus",
    "tabs",
    "storage"
  ],
  "action": {
    "default_icon": {
      "48": "icons/icon48_off.png"
    }
  },
  "icons": {
    "48": "icons/icon48_on.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "resources/3_tone_chime-99718.mp3"
      ],
      "matches": ["https://app.vetradar.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://app.vetradar.com/*"],
      "js": [
        "shared.bundle.js", // Shared dependencies
        "main.bundle.js",
        "domHandlers.bundle.js",
        "messageHandler.bundle.js",
		"audioManager.bundle.js",
		"options.bundle.js",
		"patientManager.bundle.js",
		"utilities.bundle.js"		
      ],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "https://app.vetradar.com/*"
  ],
  "options_page": "html/options.html",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}