{
  "name": "Vet Radar Notification",
  "version": "1.5",
  "manifest_version": 3,
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "graphic assets/icon16.png",
    "32": "graphic assets/icon32.png",
    "48": "graphic assets/icon48.png",
    "128": "graphic assets/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "graphic assets/icon16.png",
      "32": "graphic assets/icon32.png",
      "48": "graphic assets/icon48.png"
    },
    "default_title": "Vet Radar Extension"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "Audio/3_tone_chime-99718.mp3",
        "Audio/simple-notification-152054.mp3",
        "Audio/mixkit-doorbell-single-press-333.mp3",
        "Audio/mixkit-bell-notification-933.mp3",
        "Audio/BuddyIn.mp3",
        "Audio/Goodbye.mp3"
      ],
      "matches": ["https://app.vetradar.com/*"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["https://app.vetradar.com/*"],
      "js": ["monitor.js"]
    }
  ],
  "host_permissions": [
    "https://app.vetradar.com/*"
  ],
  "options_page": "options.html"
}
